{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Aprendento o projeto.",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up &&  npm run migration:up && next dev && npm run services:down",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d && npm run wait-for-postgres",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "lint:eslint:fix": "next lint --fix",
    "lint:all:check": "npm run lint:prettier:check && npm run lint:eslint:check",
    "test": "npm run services:up && (concurrently -n \"next,jest\" --hide \"next\" -k -s command-jest \"next dev\" \"jest --runInBand\"; EXIT_CODE=$?; npm run services:down; exit $EXIT_CODE)",
    "test:watch": "jest --runInBand --watchAll",
    "migration:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migration:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "async-retry": "^1.3.3",
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^13.1.6",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.6.0",
    "husky": "^9.1.4",
    "jest": "29.7.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": "24"
  }
}
