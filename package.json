{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Aprendento o projeto.",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up &&  npm run migration:up && next dev",
    "build": "next build",
    "start": "next start",
    "services:up": "npm run services:down && docker compose -f infra/compose.yaml up -d && npm run wait-for-postgres",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watchAll",
    "migration:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migration:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^13.1.6",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "prettier": "^3.8.1"
  }
}
