#!/bin/bash

# Cores para o terminal
RED='\033[0;31m'
NC='\033[0m' # No Color
YELLOW='\033[1;33m'

# Padrões de busca (Regex)
# 1. Chaves genéricas (API_KEY, SECRET, etc)
# 2. AWS Access Key
# 3. Private Keys (PEM/RSA)
PATTERNS="(AIza[0-9A-Za-z\\-_]{35}|AKIA[0-9A-Z]{16}|api_key|secret|password|token|-----BEGIN.*PRIVATE KEY-----)"

# Arquivos .env permitidos (para CI/CD, exemplos, etc)
ALLOWED_ENV_FILES=(
    ".env.development"
    ".env.example"
    ".env.test"
)

# Verifica arquivos que estão no "staged" (git add)
STAGED_FILES=$(git diff --cached --name-only)

EXIT_CODE=0

for FILE in $STAGED_FILES; do
    # 1. Bloqueia arquivos .env sensíveis (exceto os permitidos)
    if [[ "$FILE" == *".env"* ]]; then
        # Verifica se está na lista de permitidos
        ALLOWED=false
        for ALLOWED_FILE in "${ALLOWED_ENV_FILES[@]}"; do
            if [[ "$FILE" == "$ALLOWED_FILE" ]]; then
                ALLOWED=true
                break
            fi
        done
        
        if [[ "$ALLOWED" == false ]]; then
            echo -e "${RED}[ERRO]${NC} Tentativa de commit de arquivo sensível: ${YELLOW}$FILE${NC}"
            echo -e "Arquivos .env permitidos: ${ALLOWED_ENV_FILES[*]}"
            EXIT_CODE=1
            continue
        fi
    fi
    
    # 2. Procura padrões de chaves dentro do conteúdo do arquivo (apenas as linhas adicionadas)
    # Pula verificação em arquivos .env permitidos e no próprio pre-commit
    SKIP_CONTENT_CHECK=false
    
    # Verifica se é um arquivo .env permitido
    if [[ "$FILE" == *".env"* ]]; then
        for ALLOWED_FILE in "${ALLOWED_ENV_FILES[@]}"; do
            if [[ "$FILE" == "$ALLOWED_FILE" ]]; then
                SKIP_CONTENT_CHECK=true
                break
            fi
        done
    fi
    
    # Pula o próprio arquivo pre-commit
    if [[ "$FILE" =~ ^(.husky/pre-commit|infra/scripts/check-secrets\.sh|\.github/workflows/check-secrets\.yaml|package\.json)$ ]]; then
      SKIP_CONTENT_CHECK=true
    fi
    
    # Verifica o conteúdo apenas se não for um arquivo permitido
    if [[ "$SKIP_CONTENT_CHECK" == false ]] && git diff --cached "$FILE" | grep -E "^\+" | grep -Ev "^\+\+\+" | grep -qiE "$PATTERNS"; then
        echo -e "${RED}[ERRO]${NC} Possível credencial ou segredo detectado em: ${YELLOW}$FILE${NC}"
        echo -e "Verifique o conteúdo antes de tentar o commit novamente."
        EXIT_CODE=1
    fi
done

if [ $EXIT_CODE -ne 0 ]; then
    echo -e "\n${RED}Commit abortado para sua segurança.${NC}"
    exit 1
fi

exit 0